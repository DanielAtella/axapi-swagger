            "maxLength": 128
          },
          "WORD1": {
            "type": "string",
            "description": "WORD min value",
            "minLength": 1,
            "maxLength": 128
          },
          "WORD2": {
            "type": "string",
            "description": "WORD max value",
            "minLength": 1,
            "maxLength": 128
          },

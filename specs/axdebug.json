            "default": 0
          },
          "icmp": {
            "type": "number",
            "default": 0
          },
          "icmpv6": {
            "type": "number",
            "default": 0
          },
          "tcp": {
            "type": "number",
            "default": 0
          },
          "udp": {
            "type": "number",
            "default": 0
          },
          "prot-num": {
            "type": "number",
            "description": "protocol number",

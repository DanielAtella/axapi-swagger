  "components": {
    "schemas": {
      "harmony-controller-config-replace": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "'enable': enable config replace mode; 'disable': disable config replace mode; ",
            "default": "enable",
            "enum": [
              "enable",
              "disable"
            ]
          },
          "uuid": {
            "type": "string",
            "description": "uuid of the object",
            "minLength": 1,
            "maxLength": 64
          }
        }
      },
      "harmony-controller-partition-tenant-info-oper": {
        "type": "object",
        "properties": {
          "oper": {
            "type": "object",
            "properties": {
              "partition-name": {
                "type": "string"
              },
              "tenant-name": {
                "type": "string"
              },
              "tenant-id": {
                "type": "string"
              },
              "cluster-name": {
                "type": "string"
              },
              "cluster-id": {
                "type": "string"
              },
              "log-rate-per-sec": {
                "type": "number"
              }
            }
          }
        }
      },
      "harmony-controller-partition-tenant-info": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "description": "uuid of the object",
            "minLength": 1,
            "maxLength": 64
          }
        }
      },
      "harmony-controller-profile-oper": {
        "type": "object",
        "properties": {
          "oper": {
            "type": "object",
            "properties": {
              "overall-status": {
                "type": "string"
              },
              "heartbeat-status": {
                "type": "string"
              },
              "heartbeat-error-message": {
                "type": "string"
              },
              "service-registry": {
                "type": "string"
              },
              "service-registry-error-message": {
                "type": "string"
              },
              "registration-status": {
                "type": "string"
              },
              "registration-status-code": {
                "type": "number"
              },
              "registration-error-message": {
                "type": "string"
              },
              "deregistration-status": {
                "type": "string"
              },
              "deregistration-status-code": {
                "type": "number"
              },
              "deregistration-error-message": {
                "type": "string"
              },
              "schema-registry-status": {
                "type": "string"
              },
              "broker_info": {
                "type": "string"
              },
              "kafka-broker-state": {
                "type": "string",
                "enum": [
                  "Up",
                  "Down"
                ]
              },
              "Number-of-tenant-mapped-partitions": {
                "type": "number"
              },
              "Number-of-tenant-unmapped-partitions": {
                "type": "number"
              },
              "tunnel-status": {
                "type": "string"
              },
              "tunnel-error-message": {
                "type": "string"
              },
              "peer-device-info": {
                "type": "string"
              }
            }
          }
        }
      },
      "harmony-controller-profile-re-sync": {
        "type": "object",
        "properties": {
          "schema-registry": {
            "type": "number",
            "description": "re-sync the schema registry",
            "default": 0
          },
          "analytics-bus": {
            "type": "number",
            "description": "re-sync analtyics bus connections",
            "default": 0
          }
        }
      },
      "harmony-controller-profile-thunder-mgmt-ip": {
        "type": "object",
        "properties": {
          "ip-address": {
            "type": "string",
            "description": "IP address (IPv4 address)"
          },
          "uuid": {
            "type": "string",
            "description": "uuid of the object",
            "minLength": 1,
            "maxLength": 64
          }
        }
      },
      "harmony-controller-profile-tunnel": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "description": "'enable': Tunnel Enable; 'disable': Tunnel Disable; ",
            "default": "disable",
            "enum": [
              "enable",
              "disable"
            ]
          },
          "uuid": {
            "type": "string",
            "description": "uuid of the object",
            "minLength": 1,
            "maxLength": 64
          }
        }
      },
      "harmony-controller-profile": {
        "type": "object",
        "properties": {
          "host": {
            "type": "string",
            "description": "Set harmony controller host adddress"
          },
          "use-mgmt-port": {
            "type": "number",
            "description": "Use management port for connections",
            "default": 0
          },
          "port": {
            "type": "number",
            "description": "Set port for remote Harmony Controller, default is 8443",
            "default": 8443,
            "minimum": 1,
            "maximum": 32767
          },
          "provider": {
            "type": "string",
            "description": "provider for the harmony-controller",
            "minLength": 1,
            "maxLength": 128
          },
          "user-name": {
            "type": "string",

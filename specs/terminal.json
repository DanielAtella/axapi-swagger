  "components": {
    "schemas": {
      "terminal": {
        "type": "object",
        "properties": {
          "auto-size": {
            "type": "number",
            "description": "Enable terminal length and width automatically (not work if width or length set to 0)",
            "default": 1
          },
          "editing": {
            "type": "number",
            "description": "Enable command line editing",
            "default": 0
          },

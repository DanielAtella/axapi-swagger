  "components": {
    "schemas": {
      "threat-intel-threat-feed": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "'webroot': Configure Webroot module options; ",
            "enum": [
              "webroot"
            ]
          },
          "server": {
            "type": "string",
            "description": "Server IP or Hostname",
            "minLength": 1,
            "maxLength": 255
          },
          "port": {
            "type": "number",
            "description": "Port to query server(default 443)",
            "default": 443,
            "minimum": 1,
            "maximum": 65535
          },
          "server-timeout": {
            "type": "number",
            "description": "Server Timeout in seconds (default: 15s)",
            "default": 15,
            "minimum": 1,
            "maximum": 30
          },
          "rtu-update-disable": {
            "type": "number",
            "description": "Disables real time updates(default enable)",
            "default": 0
          },
          "update-interval": {
            "type": "number",
            "description": "Interval to check for database or RTU updates(default 120 mins)",
            "default": 120,
            "minimum": 10,
            "maximum": 14400
          },
          "use-mgmt-port": {
            "type": "number",
            "description": "Use management interface for all communication with threat-intel server",
            "default": 0
          },
          "log-level": {
            "type": "string",
            "description": "'disable': Disable all logging; 'error': Log error events; 'warning': Log warning events and above; 'info': Log info events and above; 'debug': Log debug events and above; 'trace': enable all logs; ",
            "default": "warning",
            "enum": [
              "disable",
              "error",
              "warning",
              "info",
              "debug",
              "trace"
            ]
          },
          "proxy-host": {
            "type": "string",
            "description": "Proxy server hostname or IP address",
            "minLength": 1,
            "maxLength": 255
          },
          "proxy-port": {
            "type": "number",
            "description": "Port to connect on proxy server",
            "minimum": 1,
            "maximum": 65535
          },
          "proxy-auth-type": {
            "type": "string",
            "description": "'ntlm': NTLM authentication(default); 'basic': Basic authentication; ",
            "default": "ntlm",
            "enum": [
              "ntlm",
              "basic"
            ]
          },
          "domain": {
            "type": "string",
            "description": "Realm for NTLM authentication",
            "minLength": 1,
            "maxLength": 127
          },
          "proxy-username": {
            "type": "string",
            "description": "Username for proxy authentication",
            "minLength": 1,
            "maxLength": 127
          },
          "proxy-password": {
            "type": "number",
            "description": "Password for proxy authentication",
            "default": 0
          },
          "secret-string": {
            "type": "string",
            "description": "password value",
            "minLength": 1,
            "maxLength": 127
          },
          "encrypted": {
            "type": "encrypted",
            "description": "Do NOT use this option manually. (This is an A10 reserved keyword.) (The ENCRYPTED secret string)"
          },
          "enable": {
            "type": "number",
            "description": "Enable module",
            "default": 0
          },
          "uuid": {
            "type": "string",
            "description": "uuid of the object",
            "minLength": 1,
            "maxLength": 64
          },
          "user-tag": {
            "type": "string",
            "description": "Customized tag",
            "minLength": 1,
            "maxLength": 127
          }
        }
      },
      "threat-intel-threat-list-stats": {
        "type": "object",
        "properties": {
          "name": {

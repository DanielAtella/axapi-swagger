  "components": {
    "schemas": {
      "ntp-auth-key": {
        "type": "object",
        "properties": {
          "key": {
            "type": "number",
            "description": "authentication key",
            "minimum": 1,
            "maximum": 65535
          },
          "alg-type": {
            "type": "string",
            "description": "'M': encryption using MD5; 'SHA': encryption using SHA; 'SHA1': encryption using SHA1; ",
            "enum": [
              "M",
              "SHA",
              "SHA1"
            ]
          },
          "key-type": {
            "type": "string",
            "description": "'ascii': key string in ASCII form; 'hex': key string in hex form; ",
            "enum": [
              "ascii",
              "hex"
            ]
          },
          "asc-key": {
            "type": "string",
            "minLength": 1,
            "maxLength": 20
          },
          "encrypted": {
            "type": "encrypted",
            "description": "Do NOT use this option manually. (This is an A10 reserved keyword.) (The ENCRYPTED password string)"
          },
          "hex-key": {
            "type": "string",
            "minLength": 21,
            "maxLength": 40
          },
          "hex-encrypted": {
            "type": "encrypted",
            "description": "Do NOT use this option manually. (This is an A10 reserved keyword.) (The ENCRYPTED password string)"
          },
          "uuid": {
            "type": "string",
            "description": "uuid of the object",
            "minLength": 1,
            "maxLength": 64
          }
        }
      },
      "ntp-ntp-global": {
        "type": "object",
        "properties": {

            "description": "uuid of the object",
            "minLength": 1,
            "maxLength": 64
          }
        }
      },
      "ntp-server-hostname": {
        "type": "object",
        "properties": {
          "host-servername": {
            "type": "string",
            "description": "IPV4 address, IPV6 address or host name of NTP server(string1~63)",
            "minLength": 1,
            "maxLength": 63
          },
          "key": {
            "type": "number",
            "description": "Use trusted key to authenticate this NTP server (The trusted key number to use)",
            "minimum": 1,
            "maximum": 65535
          },
          "prefer": {
            "type": "number",
            "description": "Set this NTP server as preferred",
            "default": 0
          },
          "action": {
            "type": "string",
            "description": "'enable': Enable this NTP server; 'disable': Disable this NTP server; ",
            "default": "enable",
            "enum": [
              "enable",
              "disable"
            ]
          },
          "uuid": {
            "type": "string",
            "description": "uuid of the object",
            "minLength": 1,
            "maxLength": 64
          }
        }
      },
      "ntp-server": {
        "type": "object",
        "properties": {
          "hostname-list": {
            "type": "array",
            "items": {
              "type": "hostname"
            }
          }
        }
      },
      "ntp-trusted-key": {
        "type": "object",
        "properties": {
          "key": {
            "type": "number",
            "description": "trusted key",
            "minimum": 1,
            "maximum": 65535
          },
          "uuid": {
            "type": "string",
            "description": "uuid of the object",
            "minLength": 1,
            "maxLength": 64
          }
        }
      },
      "ntp": {
        "type": "object",
        "properties": {
          "ntp-global": {
            "type": "object",
            "properties": {
              "uuid": {
